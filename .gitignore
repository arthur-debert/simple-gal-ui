node_modules/
# dist/ is shipit's release bundle STAGING tree (`shipit release bundle`'s
# default --out; wf-build uploads it wholesale) — the renderer build lives in
# dist-web/ so web assets never ride the staged release tree (#78).
dist/
dist-web/
dist-electron/

# Playwright
test-results/
playwright-report/
tests/__screenshots__/

# Vitest coverage reports
coverage/

# Bundled simple-gal binaries (downloaded at install/package time)
resources/bin/

# electron-builder output
release/

# Env
.env
.env.*
!.env.example
.DS_Store
**/.DS_Store
.padz

# Fixture scratch
tests/.tmp/

# Local gallery content (user photos — not for version control)
content/

# Claude Code working state
.claude/
