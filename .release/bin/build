#!/usr/bin/env bash
set -euo pipefail

# Canonical electron-app build entry point. Same script local + CI.
#
# Delegates to the consumer's `npm run build` script (or pnpm/yarn
# equivalent), preserving whatever build chain the consumer has wired
# in package.json. The typical chain includes:
#   * prebuild hooks (e.g. theme:check, icons, build:quicklook)
#   * dep provisioning (fetch-deps, download-* scripts)
#   * tsc / vite build (TypeScript + frontend bundle)
#   * electron-builder (the final platform bundle)
#
# Args (after `--`, or as positional) are forwarded to the underlying
# build script — most commonly to electron-builder via npm's `--` arg
# convention. Matches electron-app.yml's release-time pattern:
#   bin/build -- --linux --x64 --publish never
#   bin/build -- --mac --arm64
#
# Usage:
#   bin/build                          # default build (whatever
#                                      # `<pm> run build` runs)
#   bin/build -- --linux --x64         # forward platform flags to
#                                      # electron-builder
#   bin/build --publish never          # if your build script accepts
#                                      # the flag directly (no `--`)
#
# CWD: respects the caller's working directory. Lockfile detection
# falls back to repo root (matches the tauri-app pattern).
#
# Source of truth: arthur-debert/release templates/electron-app/bin/build.

# Resolve package manager from the lockfile. Check CWD first
# (monorepo with subdir-local lockfile), fall back to repo root.
# Lockfile IS the canonical signal; consumers commit exactly one.
detect_pm() {
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
    if [ -f pnpm-lock.yaml ] || [ -f "${root}/pnpm-lock.yaml" ]; then
        echo "pnpm"
    elif [ -f yarn.lock ] || [ -f "${root}/yarn.lock" ]; then
        echo "yarn"
    else
        echo "npm"
    fi
}

PM=$(detect_pm)

if ! command -v "${PM}" >/dev/null 2>&1; then
    echo "bin/build: ${PM} not found on \$PATH" >&2
    echo "  install: see https://nodejs.org / https://pnpm.io / https://yarnpkg.com" >&2
    exit 1
fi

# Normalize the caller-side convention `bin/build -- <inner args>`
# ('end of bin/build options, what follows is for the build tool') by
# stripping the leading `--`. We then re-forward $@ to the consumer's
# `<pm> run build` script — and the `--` semantics there diverge sharply
# across package managers (empirically, late-2026: npm 11, pnpm 10):
#
#   * npm: does NOT forward `--`-prefixed args to the script UNLESS they
#     follow a `--` separator. Without it, npm consumes `--linux`,
#     `--publish`, etc. as its own options and only bare tokens leak
#     through — so `--publish never` reached electron-builder as a lone
#     `never`, which it rejects ("Unknown argument: never"). npm strips
#     the leading `--` before handing the rest to the script, so the
#     script sees a clean `--linux --x64 --publish never`. (release#325)
#   * pnpm / yarn: forward args directly, and a leading `--` LEAKS into
#     the script's argv (`... && electron-builder -- --linux ...`).
#     electron-builder reads that `--` as end-of-options and drops
#     `--publish never` → CI-implicit publish kicks in and the build
#     dies needing GH_TOKEN. So they must NOT get a `--`. (Earlier real
#     failure: simple-gal-ui v0.1.0 build-linux, run 26317707960.)
#
# There is no single invocation that satisfies both, so branch on $PM.
if [ "$#" -gt 0 ] && [ "$1" = "--" ]; then
    shift
fi

# Delegate to the consumer's `<pm> run build` script with the separator
# each pm needs to forward args cleanly to the build tool (see above).
case "${PM}" in
    npm)
        # npm needs the `--` to forward args — but only append it when
        # there ARE args. `npm run build --` with nothing after can leak a
        # stray `--` to the script on some npm versions.
        if [ "$#" -gt 0 ]; then
            exec npm run build -- "$@"
        fi
        exec npm run build
        ;;
    *)
        exec "${PM}" run build "$@"
        ;;
esac
