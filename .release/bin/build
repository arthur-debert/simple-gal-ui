#!/usr/bin/env bash
set -euo pipefail

# Canonical electron-app build entry point. Same script local + CI.
#
# Delegates to the consumer's `npm run build` script (or pnpm/yarn
# equivalent), preserving whatever build chain the consumer has wired
# in package.json. The typical chain includes:
#   * prebuild hooks (e.g. theme:check, icons, build:quicklook)
#   * dep provisioning (fetch-deps, download-* scripts)
#   * tsc / vite build (TypeScript + frontend bundle)
#   * electron-builder (the final platform bundle)
#
# Args (after `--`, or as positional) are forwarded to the underlying
# build script — most commonly to electron-builder via npm's `--` arg
# convention. Matches electron-app.yml's release-time pattern:
#   bin/build -- --linux --x64 --publish never
#   bin/build -- --mac --arm64
#
# Usage:
#   bin/build                          # default build (whatever
#                                      # `<pm> run build` runs)
#   bin/build -- --linux --x64         # forward platform flags to
#                                      # electron-builder
#   bin/build --publish never          # if your build script accepts
#                                      # the flag directly (no `--`)
#
# CWD: respects the caller's working directory. Lockfile detection
# falls back to repo root (matches the tauri-app pattern).
#
# Source of truth: arthur-debert/release templates/electron-app/bin/build.

# Resolve package manager from the lockfile. Check CWD first
# (monorepo with subdir-local lockfile), fall back to repo root.
# Lockfile IS the canonical signal; consumers commit exactly one.
detect_pm() {
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
    if [ -f pnpm-lock.yaml ] || [ -f "${root}/pnpm-lock.yaml" ]; then
        echo "pnpm"
    elif [ -f yarn.lock ] || [ -f "${root}/yarn.lock" ]; then
        echo "yarn"
    else
        echo "npm"
    fi
}

PM=$(detect_pm)

if ! command -v "${PM}" >/dev/null 2>&1; then
    echo "bin/build: ${PM} not found on \$PATH" >&2
    echo "  install: see https://nodejs.org / https://pnpm.io / https://yarnpkg.com" >&2
    exit 1
fi

# Strip a leading `--` from $@. Caller-side convention is
# `bin/build -- <inner args>` ('end of bin/build options, what follows
# is for the underlying build tool'). We forward $@ to `<pm> run
# build`, and the `--` semantics diverge across package managers:
#
#   * npm 7+: strips a leading `--` before forwarding to the script.
#   * pnpm 10: KEEPS the literal `--` in the script's argv. When the
#     consumer's build script is a `&&`-chain ending in
#     `electron-builder`, pnpm appends only to the last command, so
#     the chain becomes `... && electron-builder -- --linux ...`.
#     electron-builder reads the first `--` as end-of-options, then
#     interprets `--linux`, `--publish never`, etc. as positional
#     args — which means `--publish never` is silently dropped,
#     CI-implicit publish kicks in, and the build dies needing
#     GH_TOKEN. (Real failure: simple-gal-ui v0.1.0 build-linux,
#     run 26317707960.)
#
# Stripping the `--` ourselves makes the forward unambiguous across
# all three pms.
if [ "$#" -gt 0 ] && [ "$1" = "--" ]; then
    shift
fi

# Delegate to the consumer's `<pm> run build` script. Args forward
# without the caller-side `--` separator (see above).
exec "${PM}" run build "$@"
