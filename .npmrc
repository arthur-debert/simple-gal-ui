# Flat node_modules layout for electron-builder compatibility.
#
# pnpm's default `isolated` node-linker uses symlinks and a content-
# addressable store, which electron-builder's file walker doesn't
# fully traverse — transitive dependencies of native/CJS packages
# like chokidar → glob-parent → is-glob → is-extglob end up missing
# from the packaged app.asar, and the first import at runtime throws
# ERR_MODULE_NOT_FOUND or Cannot find module 'is-extglob'.
#
# `hoisted` creates a flat node_modules like npm/yarn-classic, at
# the cost of some strictness around accidental access to non-declared
# deps. Acceptable trade for a working packaged build.
node-linker=hoisted
